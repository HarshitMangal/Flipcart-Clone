# Google OAuth Client ID for Google Login feature
# Generate this from Google Cloud Console (https://console.cloud.google.com/)
# Make sure to whitelist http://localhost:3000 and your Vercel URL in "Authorized JavaScript Origins"
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Backend API URL (optional for local, defaults to http://localhost:8000)
REACT_APP_API_URL=http://localhost:8000
