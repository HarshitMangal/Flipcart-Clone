# MongoDB Connection URL (Local or Cloud Atlas)
MONGO_URI=mongodb://localhost:27017/flipcart

# Razorpay Credentials (Create a free account at razorpay.com to get test keys)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# JWT Token secret for signing user sessions
JWT_SECRET=flipcart_super_secret_jwt_key_2024

# Google Gemini AI API Key (Get a free key from Google AI Studio at aistudio.google.com)
# If not provided, the chatbot falls back to a smart offline rules engine!
GEMINI_API_KEY=your_gemini_api_key_here
